# AnyKB Docker Compose env template — copy to `.env` and edit.
#
# Generate strong secrets:
#   POSTGRES_PASSWORD=$(openssl rand -hex 16)
#   JWT_SECRET=$(openssl rand -hex 32)

# ===== Required =====
POSTGRES_PASSWORD=
JWT_SECRET=

# ===== Public-facing URL (must match how users reach nginx) =====
# Used for CORS. Multiple origins: comma-separated.
PUBLIC_URL=http://localhost

# ===== BYOK gate =====
# true  (recommended for any public deploy): users MUST configure their own
#       LLM + embedding keys in /settings — owner keys never shared.
# false (dev/demo): chat falls back to the keys below when user hasn't set theirs.
BYOK_REQUIRED=true

# ===== Admin dashboard (06-01) =====
# Comma-separated emails promoted to platform admin (is_admin) on every startup.
# The account must register through the app first; on the next restart it gains
# access to /admin (stats + user management + KB management). Leave empty to
# disable seeding (admins can still be granted at runtime by an existing admin).
#   ADMIN_EMAILS=you@example.com,ops@example.com
ADMIN_EMAILS=

# ===== Optional owner-side fallback keys (only used when BYOK_REQUIRED=false) =====
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ===== Rate limit (per user, per hour) =====
RATE_LIMIT_PER_HOUR=60

# ===== Short-term memory (v3-M2 memory-optimization) =====
# REDIS_URL is wired inside docker-compose.yml (redis://redis:6379/0, a
# bundled redis:7-alpine service) — nothing to set here. To disable the
# feature entirely, blank out REDIS_URL in docker-compose.yml instead.
# Optional tuning knobs (defaults shown; uncomment to override):
#   MEMORY_WINDOW_SIZE=10          # sliding window (rounds); 0 = keep all + no compression
#   MEMORY_COMPRESSION_BATCH=5     # compress the oldest N rounds per batch
#   CONTEXT_TOTAL_BUDGET=8000      # layered-context token budget; 0 = unenforced

# ===== Memory maintenance (v3-M5 memory-optimization) =====
# Nightly background job: vector dedup + importance decay + eviction, plus a
# 24h-idle conversation scan that finalizes + extracts long-term memories. Runs
# in-process (multi-instance safe: correctness comes from idempotent DB
# predicates + CAS gates, never a single-process assumption). Defaults shown:
#   MEMORY_MAINTENANCE_ENABLED=true   # false = loop never starts (off-switch)
#   MEMORY_MAINTENANCE_HOUR=3         # UTC wall hour to run the nightly round
