# ===== LLM =====
ANTHROPIC_API_KEY=sk-ant-api03-xxx
ANTHROPIC_BASE_URL=https://api.anthropic.com
LLM_DEFAULT_MODEL=claude-haiku-4-5-20251001
LLM_COMPLEX_MODEL=claude-sonnet-4-6

# ===== Tools =====
QWEATHER_API_KEY=
AMAP_API_KEY=

# ===== Vector DB =====
# VECTOR_STORE: milvus (default, pure-Python embedded, Windows OK) | qdrant | local
VECTOR_STORE=milvus

# Milvus — pick one URI form:
#   Milvus Lite (embedded, pure Python, Windows OK):  ./data/milvus_local.db
#   Standalone / Zilliz Cloud:  http://host:19530    (set MILVUS_TOKEN too)
MILVUS_URI=./data/milvus_local.db
MILVUS_TOKEN=

# Qdrant (set VECTOR_STORE=qdrant to use; requires qdrant.exe or docker)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=restaurants

# ===== Embedding =====
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3

# ===== Server =====
APP_ENV=dev
LOG_LEVEL=INFO
RATE_LIMIT_PER_HOUR=20
CORS_ORIGINS=http://localhost:3000

# ===== Short-term memory (v3-M2 memory-optimization, PRD §9) =====
# REDIS_URL is the master switch: leave blank → feature off (pure-PG path,
# exact pre-M2 behavior). Local: redis://localhost:6379/0
# Docker: redis://redis:6379/0 (requires a redis service in docker-compose).
REDIS_URL=
# Sliding window (conversation rounds) kept verbatim in context; 0 = keep all
# AND disables compression (PRD §11 escape hatch).
MEMORY_WINDOW_SIZE=10
# Compress the oldest N rounds once N full rounds have slid out of the window.
MEMORY_COMPRESSION_BATCH=5
# Total token budget for the layered LLM context (0 = no budget enforcement).
CONTEXT_TOTAL_BUDGET=8000
# --- M3 placeholders (long-term memory; config surface only for now) ---
MEMORY_AUTO_EXTRACT=true
MEMORY_RETENTION_DAYS=90

# ===== BYOK gate (v2-M2) =====
# false (default): chat / KB ops fall back to the LLM / embedding keys above
#                  when a user hasn't configured their own in /settings.
# true:           every user MUST configure their own LLM + embedding before
#                  chat / create_kb / upload work — set this for public deploys
#                  so the project owner's keys aren't shared with all users.
BYOK_REQUIRED=false

# ===== Monitoring (v2-M7, optional) =====
# Set both to enable Logfire backend tracing:
#   1) pip install -e '.[monitoring]'   (or just `pip install logfire`)
#   2) Fill LOGFIRE_TOKEN below with a write token from https://logfire.pydantic.dev/
# Leave blank to skip — structlog logs to stdout as usual.
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME=anykb-backend
